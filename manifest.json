{
  "manifest_version": 3,
  "name": "PureShield",
  "short_name": "PureShield",
  "version": "1.0.4",
  "description": "Ad blocker, tracker blocker & halal filter. By SOCMID.",
  "author": "SOCMID",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PureShield by SOCMID",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "*://www.google.com/search*",
        "*://google.com/search*",
        "*://www.bing.com/search*",
        "*://duckduckgo.com/*",
        "*://www.youtube.com/results*"
      ],
      "js": ["halal_search.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["*://*.youtube.com/*", "*://youtube.com/*"],
      "js": ["youtube_content.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://*.youtube.com/*", "*://youtube.com/*"],
      "js": ["yt_scriptlet.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ads",
        "enabled": true,
        "path": "rules/ads.json"
      },
      {
        "id": "trackers",
        "enabled": true,
        "path": "rules/trackers.json"
      },
      {
        "id": "halal",
        "enabled": false,
        "path": "rules/halal.json"
      },
      {
        "id": "halal_extra",
        "enabled": false,
        "path": "rules/halal_extra.json"
      }
    ]
  }
}
